# Server
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed frontend origins (Vite may use 5173 or 5174)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Authentication
# Generate a strong secret (>= 32 random bytes), e.g. `openssl rand -hex 32`
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN=8h
BCRYPT_SALT_ROUNDS=12

# Database seed (used by `npm run prisma:seed`)
SEED_FACULTY_NAME="Demo Faculty"
SEED_FACULTY_EMAIL="faculty@example.com"
SEED_FACULTY_PASSWORD="ChangeMe123!"

# Supabase Storage (leave blank today; fill in during integration)
# The API boots without these; file upload/download fails clearly until set.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET="lesson-files"
MAX_FILE_SIZE_BYTES=52428800
SIGNED_URL_EXPIRES_SEC=3600

# Supabase PostgreSQL (Prisma)
# Use the connection pooler URL for runtime (DATABASE_URL)
# Use the direct connection URL for migrations (DIRECT_URL)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
