# Server
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed frontend origins
# 5173/5174 = Vite dev, 4173 = Vite preview, 8080 = Docker frontend
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:4173,http://localhost:8080

# Authentication
# Generate a strong secret (>= 32 chars), e.g. `openssl rand -hex 32`
# Production startup rejects known placeholders and secrets shorter than 32 chars.
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32"
JWT_EXPIRES_IN=8h
BCRYPT_SALT_ROUNDS=12

# Database seed (used by `npm run prisma:seed`)
SEED_FACULTY_NAME="Demo Faculty"
SEED_FACULTY_EMAIL="faculty@example.com"
SEED_FACULTY_PASSWORD="ChangeMe123!"

# Supabase Storage
# Optional at boot; upload/download return 503 until both URL + service role key are set.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET="lesson-files"
MAX_FILE_SIZE_BYTES=52428800
SIGNED_URL_EXPIRES_SEC=3600

# Supabase PostgreSQL (Prisma)
# DATABASE_URL — transaction pooler (runtime). Prefer connection_limit=1 with pgbouncer.
# DIRECT_URL — session/direct connection used by Prisma migrations.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
