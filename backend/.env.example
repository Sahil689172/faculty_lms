# =============================================================================
# Backend environment variables
# Copy to .env for local development, or set the same keys in the Render dashboard.
# =============================================================================

# --- Server ---
NODE_ENV=development
# Local only. On Render, PORT is injected automatically — do not set a conflicting value.
PORT=4000

# Comma-separated browser origins allowed to call this API.
# Local examples + your Netlify production URL (no trailing slash):
#   http://localhost:5173,https://your-site.netlify.app
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:4173

# --- Authentication (JWT) ---
# Generate with: openssl rand -hex 32
# Production rejects secrets shorter than 32 characters and known placeholders.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32
JWT_EXPIRES_IN=8h
BCRYPT_SALT_ROUNDS=12

# --- Database seed (local / one-time only; optional on Render) ---
SEED_FACULTY_NAME=Demo Faculty
SEED_FACULTY_EMAIL=faculty@example.com
SEED_FACULTY_PASSWORD=ChangeMe123!

# --- Supabase Storage (required for lesson uploads/downloads) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=lesson-files
MAX_FILE_SIZE_BYTES=52428800
SIGNED_URL_EXPIRES_SEC=3600

# --- Supabase PostgreSQL (Prisma) ---
# DATABASE_URL: Transaction pooler (runtime). Append pgbouncer + connection_limit.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL: Direct connection for migrations (db.<ref>.supabase.co:5432).
DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
