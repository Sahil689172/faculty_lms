# =============================================================================
# Frontend environment variables (Vite)
# Copy to .env for local development.
# On Netlify: Site settings → Environment variables (Production + Deploy Previews).
# =============================================================================

# Backend API base URL INCLUDING the /api prefix.
# This is baked into the JS bundle at BUILD time — change it and redeploy to update.
#
# Local:
#   VITE_API_BASE_URL=http://localhost:4000/api
# Production (Render API):
#   VITE_API_BASE_URL=https://faculty-lms-api.onrender.com/api

VITE_API_BASE_URL=http://localhost:4000/api
